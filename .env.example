# ============================================================
# ENGLI ENV — copy this to .env.local and fill in the values.
# Same values go into Vercel → Project → Settings → Environment Variables.
# Lines starting with NEXT_PUBLIC_ are exposed to the browser; everything
# else is server-only and must NEVER be prefixed with NEXT_PUBLIC_.
# ============================================================


# ====== SUPABASE ======
# Where to find these:
#   Supabase Dashboard → your project → Settings → API
#   - "Project URL"        → NEXT_PUBLIC_SUPABASE_URL
#   - "Project API keys" → "anon / public"        → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - "Project API keys" → "service_role / secret" → SUPABASE_SERVICE_ROLE_KEY  (keep secret!)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...keep_secret


# ====== STRIPE ======
# Where to find these:
#   Stripe Dashboard → Developers → API keys
#     - "Publishable key" → NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY  (optional — not used today,
#                                                                but include it now so client-side
#                                                                Stripe Elements work later)
#     - "Secret key"      → STRIPE_SECRET_KEY
#
#   Create three products at Stripe Dashboard → Product catalog → Add product:
#     - "Premium Monthly"  recurring ₾29 GEL / month
#     - "Premium Annual"   recurring ₾174 GEL / year
#     - "Family Monthly"   recurring ₾49 GEL / month
#   Click each product → copy the Price ID (starts with `price_`) into the matching var below.
#   IMPORTANT: confirm GEL is enabled on your Stripe account first
#   (Settings → Payments → Currencies). If not, bill in USD/EUR until activated.
#
#   STRIPE_WEBHOOK_SECRET:
#     Local dev → run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
#                 and copy the `whsec_...` it prints.
#     Production → Stripe Dashboard → Developers → Webhooks → Add endpoint
#                  URL: https://engli.ge/api/stripe/webhook
#                  Events to send: checkout.session.completed,
#                                  customer.subscription.updated,
#                                  customer.subscription.deleted,
#                                  invoice.payment_failed
#                  → click endpoint → reveal "Signing secret" → paste here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_ANNUAL=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_FAMILY_MONTHLY=price_xxx


# ====== ANTHROPIC (AI Tutor) ======
# Get this at console.anthropic.com → Settings → API Keys → Create Key.
# Make sure billing/credits are enabled on the account, otherwise the
# AI Tutor chat endpoint (/api/ai-tutor) will return 401.
ANTHROPIC_API_KEY=sk-ant-xxx


# ====== APP ======
# Local dev: http://localhost:3000
# Production: https://engli.ge  (no trailing slash)
# Used for Stripe checkout success/cancel redirects, so it MUST match
# the domain users actually land on, or they'll bounce after payment.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ====== ADMIN ======
# Comma-separated emails that can access /admin. The code falls back to
# nina@learneazy.org,nina@yournexttutor.com if this is unset, but set it
# explicitly in production so you don't accidentally lock yourself out.
ADMIN_EMAILS=ninashengelia18@gmail.com


# ====== UPSTASH REDIS (optional, AI Tutor rate limiting) ======
# When both vars are set, /api/ai-tutor enforces its per-user rate limit
# against an Upstash Redis ZSET sliding window — safe for multi-instance
# Vercel deployments. If either is unset, the limiter falls back to a
# per-Node-process in-memory map (fine for local dev, "best effort" on
# Vercel where requests can land on different lambdas).
#
# Get these at console.upstash.com → Redis → your database → REST API.
# UPSTASH_REDIS_REST_URL=https://us1-xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AX...


# ====== CRON ======
# Shared secret for the hearts-refill cron endpoint at
# /api/cron/refill-hearts. Vercel Cron forwards this automatically as
# `Authorization: Bearer $CRON_SECRET` when set on the project. Generate
# with `openssl rand -hex 32`. If unset, the endpoint returns 503 so you
# can't accidentally leave it open.
# CRON_SECRET=replace-with-32-byte-random-hex
